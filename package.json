{
  "name": "setup-maven",
  "version": "2.0.0",
  "private": true,
  "description": "GitHub Action to install and set up Apache Maven",
  "main": "lib/setup-maven.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build lib/setup-maven.js -o dist --source-map --license licenses.txt",
    "all": "npm run build && npm run package",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "actions",
    "maven",
    "setup",
    "java",
    "build-tools"
  ],
  "author": "batmahdi",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vercel/ncc": "^0.38.3",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3"
  }
}
